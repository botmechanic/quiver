# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dashboard auth
ADMIN_EMAIL=your-dashboard-email
ADMIN_PASSWORD=your-dashboard-password

# x402 / Circle Nanopayments
# Run `npm run generate-wallets` to auto-generate both seller and buyer wallets
SELLER_ADDRESS=0xYourWalletAddress
SELLER_PRIVATE_KEY=0xYourSellerPrivateKey

# Buyer wallet (for the payment agent and demo-funded Try Quiver buys)
BUYER_ADDRESS=0xYourBuyerWalletAddress
BUYER_PRIVATE_KEY=0xYourBuyerPrivateKey

# Demo buy controls — BASE_URL must include https:// (or http:// for localhost)
DEMO_RATE_LIMIT_SECONDS=30
DEMO_DEPOSIT_AMOUNT=0.01
BASE_URL=http://localhost:3000

# Owncast sidecar (Stage 1 adapter)
OWNCAST_URL=http://localhost:8080
OWNCAST_ACCESS_TOKEN=your-owncast-integration-token
OWNCAST_SIDECAR_PORT=8787
OWNCAST_TICK_INTERVAL_MS=1000
OWNCAST_HEARTBEAT_MS=2000
OWNCAST_MAX_TICKS=10
OWNCAST_MAX_SPEND_USDC=0.001
OWNCAST_START_ON_CHAT=true
OWNCAST_STREAMER_ID=local-owncast
OWNCAST_STREAMER_NAME="Local Owncast streamer"
OWNCAST_STREAMER_ADDRESS=0xYourStreamerWalletAddress

# LangChain deep agent (OpenAI) — optional
# If omitted, the agent runs in mock mode with scripted tool calls.
OPENAI_API_KEY=your-openai-api-key
